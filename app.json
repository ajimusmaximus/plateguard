{
  "expo": {
    "name": "PlateGuard",
    "slug": "plateguard",
    "version": "1.0.0",
    "scheme": "plateguard",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PlateGuard to access your camera to scan food barcodes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow PlateGuard to use your location to find nearby restaurants."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4CAF50"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plateguard.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "PlateGuard reads health data to support your wellness goals.",
        "NSHealthUpdateUsageDescription": "PlateGuard writes step and fitness data to Apple Health.",
        "NSMotionUsageDescription": "PlateGuard uses motion data to count your steps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.plateguard.app",
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a27eb99a-e5d1-477f-85bd-1a5a947361a4"
      }
    }
  }
}